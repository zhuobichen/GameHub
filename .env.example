# GameHub 环境变量配置
# 复制此文件为 .env 并填入真实值

# PostgreSQL
POSTGRES_USER=gamehub
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=gamehub
DATABASE_URL=postgresql+asyncpg://gamehub:your_password_here@localhost:5432/gamehub
DATABASE_URL_SYNC=postgresql://gamehub:your_password_here@localhost:5432/gamehub

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Secret (用 openssl rand -hex 32 生成)
SECRET_KEY=your_secret_key_here

# Steam API
STEAM_API_KEY=
STEAM_ID=

# AI
DEEPSEEK_API_KEY=

# RAWG
RAWG_API_KEY=

# Social Media APIs (可选)
YOUTUBE_API_KEY=
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Email (可选)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
